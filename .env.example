# ====================================================
# Wisp — Duch Lasu | Konfiguracja serwera
# Skopiuj do .env i uzupełnij wartości
# NIGDY nie commituj .env do git!
# ====================================================

# Stripe — klucze ze stripe.com/dashboard
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth — console.cloud.google.com
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# JWT — wygeneruj: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=wpisz_tutaj_dlugi_losowy_string_minimum_32_znaki

# Domena gry (bez trailing slash)
BASE_URL=https://wisp.twojadomena.pl

# Port backendu (nie zmieniaj — nginx proxuje na 3001)
PORT=3001

NODE_ENV=production
